ENVIRONMENT=development
APP_NAME=OneTapGOV API
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onetapgov
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CORS_ORIGINS=["http://localhost:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_REQUESTS=20
AI_PROVIDER=stub
AI_MODEL=structured-extractor-v1
AI_COST_PER_1K_INPUT_TOKENS=0
AI_COST_PER_1K_OUTPUT_TOKENS=0
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
LOG_LEVEL=INFO
ENABLE_DOCS=true

# Email (SMTP) Notification Provider
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@onetapgov.in

# SMS & WhatsApp Notification Provider (Twilio)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Push Notification Provider (Firebase)
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_ACCESS_TOKEN=
